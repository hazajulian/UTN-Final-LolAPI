{
  "openapi": "3.0.3",
  "info": {
    "title": "LoL API v1",
    "version": "1.0.0",
    "description": "API for League of Legends champions and user features.\n\nProtected routes require a Session Token via Authorization header:\nAuthorization: Bearer <sessionToken>\n\nNote: This token is not necessarily a JWT. It's a session token generated by the API."
  },
  "servers": [
    {
      "url": "http://localhost:3010",
      "description": "Local server"
    }
  ],
  "tags": [
    { "name": "Meta", "description": "Health and metadata" },
    { "name": "Auth", "description": "Authentication and user management" },
    { "name": "Champions", "description": "Champions endpoints (seed and custom)" },
    { "name": "Items", "description": "Item Shop (Data Dragon)" },
    { "name": "Contact", "description": "Contact endpoint (protected)" }
  ],
  "components": {
    "securitySchemes": {
      "sessionAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "SessionToken",
        "description": "Use the sessionToken returned by /api/v1/auth/login. Example: Authorization: Bearer <sessionToken>"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "error" },
          "message": { "type": "string", "example": "Error message" },
          "details": { "type": "array", "items": { "type": "string" } }
        }
      },
      "MetaResponse": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "example": "LoL API" },
          "status": { "type": "string", "example": "ok" },
          "time": { "type": "string", "format": "date-time" },
          "docs": {
            "type": "object",
            "properties": {
              "en": { "type": "string", "example": "/swagger.json" },
              "es": { "type": "string", "example": "/swagger-es.json" }
            }
          }
        }
      },
      "ItemsModuleMetaResponse": {
        "type": "object",
        "properties": {
          "module": { "type": "string", "example": "items" },
          "ddragonVersion": { "type": "string", "example": "16.1.1" },
          "locales": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["en_US", "es_ES"]
          },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "TagsResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "locale": { "type": "string", "example": "en_US" },
              "total": { "type": "integer", "example": 31 }
            }
          },
          "data": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["Boots", "Armor", "Damage"]
          }
        }
      },
      "ItemGold": {
        "type": "object",
        "properties": {
          "base": { "type": "integer", "example": 300 },
          "total": { "type": "integer", "example": 300 },
          "sell": { "type": "integer", "example": 210 },
          "purchasable": { "type": "boolean", "example": true }
        }
      },
      "ItemMini": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "66965d5615bed700c126e7dc" },
          "itemId": { "type": "string", "example": "3005" },
          "gold": {
            "type": "object",
            "properties": {
              "total": { "type": "integer", "example": 1000 }
            }
          },
          "iconUrl": { "type": "string", "format": "uri" },
          "name": { "type": "string", "example": "Ghostcrawlers" }
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "itemId": { "type": "string", "example": "1001" },
          "locale": { "type": "string", "example": "en_US" },
          "name": { "type": "string", "example": "Boots" },
          "plaintext": { "type": "string", "example": "Slightly increases Move Speed" },
          "descriptionRaw": { "type": "string", "example": "<mainText><stats><attention>25</attention> Move Speed</stats><br><br></mainText>" },
          "descriptionText": { "type": "string", "example": "25 Move Speed" },
          "gold": { "$ref": "#/components/schemas/ItemGold" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["Boots"]
          },
          "from": {
            "type": "array",
            "items": { "type": "string" },
            "example": []
          },
          "into": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["3005", "3047"]
          },
          "maps": {
            "type": "object",
            "additionalProperties": { "type": "boolean" },
            "example": { "11": true, "12": true, "21": true }
          },
          "imageFull": { "type": "string", "example": "1001.png" },
          "iconUrl": { "type": "string", "format": "uri" },
          "inStore": { "type": "boolean", "example": true },
          "hideFromAll": { "type": "boolean", "example": false },
          "requiredChampion": { "type": "string", "example": "" },
          "requiredAlly": { "type": "string", "example": "" },
          "ddragonVersion": { "type": "string", "example": "16.1.1" },
          "id": { "type": "string", "example": "66965d5615bed700c126e74e" },
          "fromItems": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ItemMini" }
          },
          "intoItems": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ItemMini" }
          }
        }
      },
      "ItemListItem": {
        "type": "object",
        "properties": {
          "itemId": { "type": "string", "example": "1001" },
          "locale": { "type": "string", "example": "en_US" },
          "name": { "type": "string", "example": "Boots" },
          "plaintext": { "type": "string", "example": "Slightly increases Move Speed" },
          "iconUrl": { "type": "string", "format": "uri" },
          "tags": { "type": "array", "items": { "type": "string" }, "example": ["Boots"] },
          "gold": {
            "type": "object",
            "properties": {
              "total": { "type": "integer", "example": 300 }
            }
          }
        }
      },
      "PaginatedItems": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "page": { "type": "integer" },
              "limit": { "type": "integer" },
              "totalPages": { "type": "integer" }
            }
          },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ItemListItem" }
          }
        }
      },
      "AllItemsResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "locale": { "type": "string", "example": "en_US" },
              "total": { "type": "integer" }
            }
          },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ItemListItem" }
          }
        }
      },
      "AuthUser": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "65f0c9c2d6c6f2b2a6b0a111" },
          "username": { "type": "string", "example": "usertest" },
          "email": { "type": "string", "example": "example@gmail.com" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "user": { "$ref": "#/components/schemas/AuthUser" },
          "token": { "type": "string", "example": "ffd86bb66e72c23a8cbae0d44dc3ea86..." }
        }
      },
      "RegisterBody": {
        "type": "object",
        "required": ["username", "email", "password"],
        "properties": {
          "username": { "type": "string", "example": "usertest" },
          "email": { "type": "string", "example": "example@gmail.com" },
          "password": { "type": "string", "example": "1234" }
        }
      },
      "LoginBody": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "example": "example@gmail.com" },
          "password": { "type": "string", "example": "1234" }
        }
      },
      "ForgotPasswordBody": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "example": "example@gmail.com" }
        }
      },
      "ResetPasswordBody": {
        "type": "object",
        "required": ["token", "newPassword", "confirmPassword"],
        "properties": {
          "token": { "type": "string", "example": "48c0f4c2ab7fa50e9bc497e0a858d..." },
          "newPassword": { "type": "string", "example": "newpass" },
          "confirmPassword": { "type": "string", "example": "newpass" }
        }
      },
      "UpdateProfileBody": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "username": { "type": "string", "example": "newusername" },
          "email": { "type": "string", "example": "newemail@gmail.com" },
          "password": { "type": "string", "example": "1234" }
        }
      },
      "ChangePasswordBody": {
        "type": "object",
        "required": ["oldPassword", "newPassword", "confirmPassword"],
        "properties": {
          "oldPassword": { "type": "string", "example": "1234" },
          "newPassword": { "type": "string", "example": "newpass" },
          "confirmPassword": { "type": "string", "example": "newpass" }
        }
      },
      "DeleteAccountBody": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "password": { "type": "string", "example": "newpass" }
        }
      },

      "Skin": {
        "type": "object",
        "required": ["name", "splashUrl", "loadingUrl"],
        "properties": {
          "name": { "type": "string", "example": "Fiddlesticks Star Nemesis" },
          "splashUrl": {
            "type": "string",
            "format": "uri",
            "description": "Large horizontal image (desktop)",
            "example": "https://ddragon.leagueoflegends.com/cdn/img/champion/splash/Fiddlesticks_10.jpg"
          },
          "loadingUrl": {
            "type": "string",
            "format": "uri",
            "description": "Vertical image (mobile / loading)",
            "example": "https://ddragon.leagueoflegends.com/cdn/img/champion/loading/Fiddlesticks_10.jpg"
          },
          "imageUrl": {
            "type": "string",
            "format": "uri",
            "description": "Legacy (compatibility). Usually equals splashUrl.",
            "example": "https://ddragon.leagueoflegends.com/cdn/img/champion/splash/Fiddlesticks_10.jpg"
          }
        }
      },

      "ChampionSummary": {
        "type": "object",
        "required": ["id", "name", "positions", "region"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "title": { "type": "string" },
          "iconUrl": { "type": "string", "format": "uri" },
          "splashUrl": { "type": "string", "format": "uri" },
          "region": { "type": "string" },
          "positions": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Champion": {
        "allOf": [
          { "$ref": "#/components/schemas/ChampionSummary" },
          {
            "type": "object",
            "properties": {
              "seed": { "type": "boolean" },
              "owner": { "type": "string" },
              "roles": { "type": "array", "items": { "type": "string" } },
              "skins": { "type": "array", "items": { "$ref": "#/components/schemas/Skin" } },
              "lore": { "type": "string" },
              "allytips": { "type": "array", "items": { "type": "string" } },
              "enemytips": { "type": "array", "items": { "type": "string" } },
              "info": { "type": "object" },
              "stats": { "type": "object" },
              "abilities": { "type": "object" }
            }
          }
        ]
      },
      "PaginatedChampionSummaries": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "page": { "type": "integer" },
              "limit": { "type": "integer" },
              "totalPages": { "type": "integer" }
            }
          },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ChampionSummary" }
          }
        }
      },
      "CreateChampionBody": {
        "type": "object",
        "required": ["id", "name", "region", "positions"],
        "properties": {
          "id": { "type": "string", "example": "MyUniqueChamp" },
          "name": { "type": "string", "example": "My Champion" },
          "title": { "type": "string", "example": "The Legendary" },
          "region": { "type": "string", "example": "Runeterra" },
          "positions": {
            "type": "array",
            "items": { "type": "string", "enum": ["Top", "Jungle", "Mid", "ADC", "Support"] },
            "example": ["Mid"]
          },
          "roles": { "type": "array", "items": { "type": "string" }, "example": ["Mage"] },
          "lore": { "type": "string", "example": "A custom champion." },
          "allytips": { "type": "array", "items": { "type": "string" } },
          "enemytips": { "type": "array", "items": { "type": "string" } }
        }
      },
      "UpdateChampionBody": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "title": { "type": "string" },
          "region": { "type": "string" },
          "positions": { "type": "array", "items": { "type": "string" } },
          "roles": { "type": "array", "items": { "type": "string" } },
          "lore": { "type": "string" }
        }
      },
      "ContactBody": {
        "type": "object",
        "properties": {
          "subject": { "type": "string", "example": "Hello" },
          "message": { "type": "string", "example": "I want to contact you." }
        }
      }
    }
  },
  "paths": {
    "/api/v1/meta": {
      "get": {
        "tags": ["Meta"],
        "summary": "API metadata and health check",
        "responses": {
          "200": {
            "description": "API metadata",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MetaResponse" }
              }
            }
          }
        }
      }
    },
    "/swagger.json": {
      "get": {
        "tags": ["Meta"],
        "summary": "OpenAPI spec (EN)",
        "responses": {
          "200": { "description": "OpenAPI JSON" }
        }
      }
    },
    "/swagger-es.json": {
      "get": {
        "tags": ["Meta"],
        "summary": "OpenAPI spec (ES)",
        "responses": {
          "200": { "description": "OpenAPI JSON" }
        }
      }
    },
    "/api/v1/items": {
      "get": {
        "tags": ["Items"],
        "summary": "List items (paginated + filters)",
        "description": "Paginated list of items. Supports text search and tag filters.\n\nRecommended params: lang, page, limit, search, tags.",
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "default": "en" },
            "description": "Language: en | es"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1, "minimum": 1 },
            "description": "Page number"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 20, "minimum": 1, "maximum": 200 },
            "description": "Items per page"
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Search text (name/description)"
          },
          {
            "name": "tags",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "example": "Boots,Armor" },
            "description": "Comma-separated tags (e.g.: Boots,Armor)"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedItems" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/api/v1/items/all": {
      "get": {
        "tags": ["Items"],
        "summary": "List all items (lightweight)",
        "description": "Returns a lightweight list (UI-friendly). Useful to load a catalog and filter on the frontend.",
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "default": "en" },
            "description": "Language: en | es"
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Search text"
          },
          {
            "name": "tags",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "example": "Boots,Armor" },
            "description": "Comma-separated tags"
          }
        ],
        "responses": {
          "200": {
            "description": "Lightweight list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AllItemsResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/api/v1/items/tags": {
      "get": {
        "tags": ["Items"],
        "summary": "List available tags (for UI filters)",
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "default": "en" },
            "description": "Language: en | es"
          }
        ],
        "responses": {
          "200": {
            "description": "Tags",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TagsResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/api/v1/items/meta": {
      "get": {
        "tags": ["Items"],
        "summary": "Items module metadata",
        "description": "Returns module metadata (Data Dragon version, available locales, updatedAt).",
        "responses": {
          "200": {
            "description": "Items meta",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ItemsModuleMetaResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/items/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "Item id (e.g. 1001)"
        }
      ],
      "get": {
        "tags": ["Items"],
        "summary": "Get item details by id",
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "default": "en" },
            "description": "Language: en | es"
          }
        ],
        "responses": {
          "200": {
            "description": "Item details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Item" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RegisterBody" } } }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "409": { "description": "Email or username already in use" }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginBody" } } }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Invalid credentials" },
          "429": { "description": "Too many attempts" }
        }
      }
    },
    "/api/v1/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Request password reset",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ForgotPasswordBody" } } }
        },
        "responses": {
          "200": { "description": "OK (generic message)" },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "429": { "description": "Too many attempts" }
        }
      }
    },
    "/api/v1/auth/reset-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Reset password",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ResetPasswordBody" } } }
        },
        "responses": {
          "200": { "description": "Password reset successfully" },
          "400": { "description": "Invalid token or validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current user profile",
        "security": [{ "sessionAuth": [] }],
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout (invalidate session token)",
        "security": [{ "sessionAuth": [] }],
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/auth/profile": {
      "put": {
        "tags": ["Auth"],
        "summary": "Update profile (requires password confirmation)",
        "security": [{ "sessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateProfileBody" } } }
